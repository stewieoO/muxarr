<div class="input-group">
    <input type="@(_visible ? "text" : "password")" class="form-control"
           value="@Value"
           @onchange="OnInputChange"
           placeholder="@Placeholder"/>
    <button type="button" class="btn btn-outline-secondary" @onclick="Toggle" tabindex="-1">
        <i class="bi @(_visible ? "bi-eye-slash" : "bi-eye")"></i>
    </button>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "";

    private bool _visible;

    private void Toggle() => _visible = !_visible;

    private Task OnInputChange(ChangeEventArgs e) =>
        ValueChanged.InvokeAsync(e.Value?.ToString() ?? "");
}
