<tr>
    <td>
        @Track.TrackNumber
    </td>
    <td>
        <MediaTrackLabel Track="Track" ShowAllFlags="true"></MediaTrackLabel>
        @if (ResolvedLanguage != null)
        {
            <i class="bi bi-arrow-right text-info mx-1"></i>
            <span class="badge bg-info text-white">@ResolvedLanguage</span>
        }

        @if (DisplayLanguage == OriginalLanguage)
        {
            <ToolTip
                Tip="@(ResolvedLanguage != null ? $"Undetermined -> {ResolvedLanguage} (original language)" : "Original Language")">
                <i class="bi bi-star-fill text-warning ms-2"></i>
            </ToolTip>
        }
        @if (!IsAllowed)
        {
            <ToolTip Tip="Redundant track - will be removed">
                <i class="bi bi-x-circle-fill text-danger ms-2"></i>
            </ToolTip>
        }
    </td>
    <td><code>@Track.Codec.FormatCodec()</code></td>
    <td>
        @if (HasMetadataChange)
        {
            <ToolTip Tip="@MetadataChangeTip">
                <i class="bi bi-pencil-square text-info me-2"></i>
            </ToolTip>
        }
        @if (!string.IsNullOrEmpty(Track.TrackName))
        {
            <span
                class="text-muted small me-2 @(HasTrackNameChange ? "text-decoration-line-through" : "")">@Track.TrackName</span>
        }
        @if (HasTrackNameChange && !string.IsNullOrEmpty(Preview?.TrackName))
        {
            <span class="small text-info">@Preview.TrackName</span>
        }
    </td>
</tr>

@code {
    [Parameter][EditorRequired] public IMediaTrack Track { get; set; } = default!;

    [Parameter][EditorRequired] public bool IsAllowed { get; set; }

    [Parameter][EditorRequired] public string? OriginalLanguage { get; set; }

    [Parameter] public TrackSnapshot? Preview { get; set; }

    private string? ResolvedLanguage =>
        Preview != null && Preview.LanguageName != Track.LanguageName ? Preview.LanguageName : null;

    private string DisplayLanguage => ResolvedLanguage ?? Track.LanguageName;

    private bool HasTrackNameChange =>
        Preview != null && !string.Equals(Track.TrackName ?? "", Preview.TrackName ?? "", StringComparison.Ordinal);

    private bool HasMetadataChange =>
        HasTrackNameChange
        || (Preview != null && (
            Preview.LanguageName != Track.LanguageName
            || Preview.IsDefault != Track.IsDefault
            || Preview.IsForced != Track.IsForced));

    private string MetadataChangeTip
    {
        get
        {
            var parts = new List<string>();
            if (Preview != null && Preview.LanguageName != Track.LanguageName)
            {
                parts.Add($"Language: {Track.LanguageName} → {Preview.LanguageName}");
            }

            if (Preview != null && !string.Equals(Track.TrackName ?? "", Preview.TrackName ?? "", StringComparison.Ordinal))
            {
                parts.Add(string.IsNullOrEmpty(Preview.TrackName)
                    ? "Track name will be cleared"
                    : $"Track name → {Preview.TrackName}");
            }

            if (Preview != null && Preview.IsDefault != Track.IsDefault)
            {
                parts.Add(Preview.IsDefault ? "Will be set as default" : "Will be unset as default");
            }

            if (Preview != null && Preview.IsForced != Track.IsForced)
            {
                parts.Add(Preview.IsForced ? "Will be set as forced" : "Will be unset as forced");
            }

            return string.Join("\n", parts);
        }
    }

}
