<table class="table table-sm mb-0">
    <thead>
    <tr>
        <th style="width: 35px;">#</th>
        <th>Language</th>
        <th>Format</th>
        <th>Details</th>
        <th style="width: 50px;"></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in KeptTracks)
    {
        <MediaTrackDetail Track="item.Original"
                          Preview="item.Preview"
                          OriginalLanguage="@OriginalLanguage"
                          PositionChange="item.PositionChange"/>
    }
    @foreach (var track in RemovedTracks)
    {
        <tr class="opacity-50">
            <td>@track.TrackNumber</td>
            <td>
                <MediaTrackLabel Track="track" ShowAllFlags="true"/>
            </td>
            <td><code>@track.Codec.FormatCodec()</code></td>
            <td></td>
            <td><i class="bi bi-x-circle-fill text-danger"></i></td>
        </tr>
    }
    </tbody>
</table>

@code {
    [Parameter] [EditorRequired] public IEnumerable<IMediaTrack> Tracks { get; set; } = default!;
    [Parameter] public List<TrackSnapshot>? PreviewTracks { get; set; }
    [Parameter] [EditorRequired] public string? OriginalLanguage { get; set; }

    private record TrackWithPreview(IMediaTrack Original, TrackSnapshot? Preview, int? PositionChange);

    private List<TrackWithPreview> KeptTracks { get; set; } = [];
    private List<IMediaTrack> RemovedTracks { get; set; } = [];

    protected override void OnParametersSet()
    {
        if (PreviewTracks == null || PreviewTracks.Count == 0)
        {
            KeptTracks = Tracks.Select(t => new TrackWithPreview(t, null, null)).ToList();
            RemovedTracks = [];
            return;
        }

        var previewByNumber = PreviewTracks.ToDictionary(p => p.TrackNumber);
        var originalPositions = Tracks.Select((t, i) => (t.TrackNumber, Index: i))
            .ToDictionary(x => x.TrackNumber, x => x.Index);

        // Kept tracks in preview order (the future state)
        KeptTracks = [];
        for (var i = 0; i < PreviewTracks.Count; i++)
        {
            var preview = PreviewTracks[i];
            var original = Tracks.FirstOrDefault(t => t.TrackNumber == preview.TrackNumber);
            if (original == null)
            {
                continue;
            }

            int? posChange = null;
            if (originalPositions.TryGetValue(preview.TrackNumber, out var origPos) && origPos != i)
            {
                posChange = i - origPos;
            }

            KeptTracks.Add(new TrackWithPreview(original, preview, posChange));
        }

        // Removed tracks (in original not in preview)
        RemovedTracks = Tracks.Where(t => !previewByNumber.ContainsKey(t.TrackNumber)).ToList();
    }

}
