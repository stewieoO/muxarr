@page "/library/{Id:int}"
@using Muxarr.Web.Components.Pages.Conversions
@inherits DisposableComponent
@attribute [StreamRendering]

<PageTitle>@TitleHelper.GetTitle("Media Details")</PageTitle>

<div class="container-fluid">
    @if (File == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            File not found
        </div>
        return;
    }
    <nav class="mb-2">
        <a href="/library" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Library
        </a>
    </nav>
    <h2 class="mb-3 text-break">
        <i class="bi bi-file-earmark-play me-2"></i>@File.GetName()
    </h2>

    @{
        var isOverride = _selectedProfileId != File.ProfileId;
        var assignedProfileName = File.Profile?.Name ?? "none";
    }
    <div class="border rounded p-3 mb-4 @(isOverride ? "border-info" : "")">
        @if (_profiles.Count > 0)
        {
            <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <label for="profileSelect" class="form-label mb-0 fw-semibold">Profile</label>
                    <select id="profileSelect" class="form-select form-select-sm" style="width: auto; min-width: 180px;"
                            value="@_selectedProfileId"
                            @onchange="OnPreviewProfileChanged">
                        @foreach (var p in _profiles)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="form-check form-switch mb-0 ms-auto">
                    <input type="checkbox" class="form-check-input" id="previewToggle"
                           checked="@_showPreview" @onchange="() => _showPreview = !_showPreview"/>
                    <label class="form-check-label small text-muted" for="previewToggle">Preview changes</label>
                </div>
            </div>

            @if (isOverride)
            {
                <div class="alert alert-info py-2 px-3 mb-3 small">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    This file is assigned to <strong>@assignedProfileName</strong>. Queueing will use
                    <strong>@_selectedProfile?.Name</strong> as a one-time override.
                </div>
            }
        }
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="AddToQueue" disabled="@IsAddToQueueDisabled"
                    title="@(IsAddToQueueDisabled ? "A conversion is already queued or running for this file" : null)">
                <i class="bi bi-plus-lg me-2"></i>Add to Queue
            </button>
            <button class="btn btn-outline-primary" @onclick="CustomConversion">
                <i class="bi bi-sliders me-2"></i>Custom Conversion
            </button>
            <button class="btn btn-outline-secondary" @onclick="AnalyzeFile">
                <i class="bi bi-search me-2"></i>Analyze File
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- File Information -->
        <div class="col-md-6">
            <div class="border rounded p-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-file-earmark text-primary me-2"></i>
                    <h5 class="mb-0">File Info</h5>
                </div>

                <div class="list-group list-group-flush bg-transparent">
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Filename</div>
                        <code class="small">@Path.GetFileName(File.Path)</code>
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Directory</div>
                        <span class="small">@Path.GetDirectoryName(File.Path)</span>
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Created</div>
                        <TimeAgo DateTime="File.FileCreationTime"/>
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Original Language</div>
                        <span>@(string.IsNullOrEmpty(File.OriginalLanguage) ? "-" : File.OriginalLanguage)</span>
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Assigned profile</div>
                        @if (File.Profile != null)
                        {
                            <a href="/settings/profile/@File.ProfileId">@File.Profile.Name</a>
                            <small class="text-muted ms-1">(matched by directory)</small>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Size</div>
                        <FileSize SizeInBytes="File.Size"/>
                    </div>
                    <div class="list-group-item bg-transparent px-0">
                        <div class="text-muted small mb-1">Added</div>
                        <TimeAgo DateTime="File.CreatedDate"/>
                    </div>
                </div>
            </div>
        </div>

        <!-- Media Information -->
        <div class="col-md-6">
            <div class="border rounded p-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-collection text-primary me-2"></i>
                    <h5 class="mb-0">Media Tracks</h5>
                    @if (_showPreview && _selectedProfile != null)
                    {
                        <span class="badge bg-info-subtle text-info-emphasis ms-2 small">
                            <i class="bi bi-eye me-1"></i>Preview: @_selectedProfile.Name
                        </span>
                    }
                </div>
                <div class="table-responsive">
                    @if (File.Tracks.Any())
                    {
                        <MediaTrackDetailTable Tracks="File.Tracks"
                                               PreviewTracks="_showPreview ? PreviewTracks : null"
                                               OriginalLanguage="@File.OriginalLanguage"/>
                    }
                    else
                    {
                        <span>No tracks found!</span>
                    }
                </div>
            </div>
        </div>

        @if (File.Conversions.Count > 0)
        {
            <div class="col-12">
                <div class="border rounded p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-terminal text-primary me-2"></i>
                        <h5 class="mb-0">Conversions</h5>
                    </div>
                    <ConversionTable Items="File.Conversions" OnCancelled="LoadFile"></ConversionTable>
                </div>
            </div>
        }

        <!-- Probe Output -->
        @if (!string.IsNullOrEmpty(File.ProbeOutput))
        {
            <div class="col-12">
                <div class="border rounded p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-terminal text-primary me-2"></i>
                        <h5 class="mb-0">Probe Output</h5>
                    </div>
                    <div class="border rounded">
                        <pre class="m-0 p-3 small bg-body-tertiary text-body"
                             style="max-height: 500px; overflow: auto;"><code
                                class="text-body">@File.ProbeOutput</code></pre>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }
    [Inject] public required MediaConverterService MediaConverter { get; set; }
    [Inject] public required MediaScannerService MediaScanner { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [Inject] public required IModalService ModalService { get; set; }

    [Parameter] public int Id { get; set; }

    protected MediaFile? File { get; set; }
    protected List<TrackSnapshot>? PreviewTracks { get; set; }
    private List<Profile> _profiles = new();
    private bool _showPreview = true;
    private int _selectedProfileId;
    private Profile? _selectedProfile;
    private bool _isSubmitting;

    private bool IsAddToQueueDisabled =>
        _isSubmitting || File?.Conversions.Any(c =>
            c.State == ConversionState.New || c.State == ConversionState.Processing) == true;

    protected override async Task OnInitializedAsync()
    {
        MediaConverter.ConverterStateChanged += OnConverterStateChanged;
        await LoadFile();
    }

    private async Task LoadFile()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        File = await context.MediaFiles
            .WithTracksAndProfile()
            .Include(x => x.Conversions
                .OrderByDescending(y => y.CreatedDate)
                .Take(5)
            ).FirstOrDefaultAsync(f => f.Id == Id);
        if (File == null)
        {
            return;
        }

        // Needed to fix order.
        File.Conversions = File.Conversions.OrderByDescending(x => x.CreatedDate).ToList();
        _profiles = await context.Profiles.OrderBy(p => p.Name).ToListAsync();
        _selectedProfileId = File.ProfileId;
        _selectedProfile = _profiles.FirstOrDefault(p => p.Id == _selectedProfileId);
        PreviewTracks = File.GetPreviewTracks(_selectedProfile);
    }

    private void OnConverterStateChanged(object? sender, ConverterProgressEvent e)
    {
        _ = InvokeAsync(async () =>
        {
            if (File == null || e.Conversion.MediaFileId != File.Id)
            {
                return;
            }

            var conversion = File.Conversions.FirstOrDefault(x => x.Id == e.Conversion.Id);
            if (conversion == null)
            {
                // New conversion for this file started elsewhere; refresh to pick it up.
                await LoadFile();
                StateHasChanged();
                return;
            }

            if (e.Conversion is { State: ConversionState.Completed, MediaFile: not null })
            {
                conversion.SizeAfter = e.Conversion.MediaFile.Size;
                conversion.TracksAfter = e.Conversion.MediaFile.Tracks.ToSnapshots();
                conversion.SizeDifference = e.Conversion.SizeDifference;
                ToastService.ShowInfo($"Finished {e.Conversion.MediaFile.GetName()}!");

                await LoadFile();
                StateHasChanged();
                return;
            }

            conversion.Progress = e.Conversion.Progress;
            conversion.State = e.Conversion.State;

            StateHasChanged();
        });
    }

    private async Task AddToQueue()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        try
        {
            if (!await MediaConverter.AddMediaToQueue(File!, _selectedProfile))
            {
                ToastService.ShowError($"'{File!.GetName()}' is not accessible. The file or its mount may be offline.");
                return;
            }

            await LoadFile();
            ToastService.ShowSuccess($"File {File!.GetName()} was added to conversion queue!");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task CustomConversion()
    {
        var selectedTracks = await ModalService.ShowCustomConversion(File!.Tracks, _profiles, _selectedProfile, File.OriginalLanguage);
        if (selectedTracks == null)
        {
            return;
        }

        if (!await MediaConverter.AddMediaToQueue(File!, selectedTracks))
        {
            ToastService.ShowError($"'{File!.GetName()}' is not accessible. The file or its mount may be offline.");
            return;
        }

        await LoadFile();
        ToastService.ShowSuccess($"Custom conversion for {File!.GetName()} was added to queue!");
    }

    private void OnPreviewProfileChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedProfileId = id;
            _selectedProfile = _profiles.FirstOrDefault(p => p.Id == id);
            PreviewTracks = File!.GetPreviewTracks(_selectedProfile);
        }
    }

    private async Task AnalyzeFile()
    {
        ToastService.ShowInfo($"Analyzing {File!.GetName()}...");
        await using var context = await ContextFactory.CreateDbContextAsync();
        var dbFile = await context.MediaFiles.WithTracksAndProfile().FirstOrDefaultAsync(f => f.Id == File!.Id);
        if (dbFile == null)
        {
            ToastService.ShowError("File not found.");
            return;
        }

        await MediaScanner.ScanMediaFile(dbFile, true, context, dbFile.Profile);
        await LoadFile();
        ToastService.ShowSuccess($"Analysis complete for {dbFile.GetName()}.");
    }

    public override void Dispose()
    {
        MediaConverter.ConverterStateChanged -= OnConverterStateChanged;
        base.Dispose();
    }

}