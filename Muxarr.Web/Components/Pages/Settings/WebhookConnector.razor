@using Muxarr.Core.Api
@using Muxarr.Core.Config

<div class="border rounded p-4">
    <div class="d-flex align-items-center mb-3">
        <i class="bi @IconClass text-primary me-2"></i>
        <h5 class="mb-0">@Name</h5>
        @if (Status != null)
        {
            <span class="badge ms-2 @StatusBadgeClass">@FormatStatus(Status.Value)</span>
        }
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="Connect" disabled="@_isBusy">
            @if (_isBusy)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            <i class="bi bi-plug me-1"></i>Connect
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="Disconnect" disabled="@_isBusy">
            <i class="bi bi-x-circle me-1"></i>Disconnect
        </button>
    </div>
</div>

@code {
    private bool _isBusy;

    [Parameter, EditorRequired] public required string Name { get; set; }
    [Parameter, EditorRequired] public required string ConfigKey { get; set; }
    [Parameter, EditorRequired] public required Func<string> GetWebhookUrl { get; set; }
    [Parameter] public ConnectStatus? Status { get; set; }
    [Parameter] public EventCallback<ConnectStatus> StatusChanged { get; set; }

    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [Inject] public required ArrApiClient ArrApi { get; set; }

    private string IconClass => Name == "Sonarr" ? "bi-tv" : "bi-film";

    private string StatusBadgeClass => Status switch
    {
        ConnectStatus.Connected => "text-bg-success",
        ConnectStatus.NotConfigured => "text-bg-secondary",
        _ => "text-bg-danger"
    };

    private async Task Connect()
    {
        var webhookUrl = GetWebhookUrl();
        if (string.IsNullOrWhiteSpace(webhookUrl) || webhookUrl.Contains("<muxarr-host>"))
        {
            ToastService.ShowWarning("Please set the Muxarr URL first and save settings.");
            return;
        }

        _isBusy = true;
        StateHasChanged();

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var arrConfig = context.Configs.GetOrDefault<ArrConfig>(ConfigKey);

            if (string.IsNullOrWhiteSpace(arrConfig.Url) || string.IsNullOrWhiteSpace(arrConfig.ApiKey))
            {
                ToastService.ShowWarning($"{Name} is not configured. Set it up in *Arr Settings first.");
                return;
            }

            var existing = await ArrApi.FindMuxarrNotification(arrConfig);

            bool success;
            if (existing != null)
            {
                success = await ArrApi.UpdateWebhookNotification(arrConfig, existing, webhookUrl);
            }
            else
            {
                success = await ArrApi.CreateWebhookNotification(arrConfig, webhookUrl);
            }

            if (success)
            {
                ToastService.ShowSuccess($"Webhook {(existing != null ? "updated" : "created")} in {Name}!");
                await StatusChanged.InvokeAsync(ConnectStatus.Connected);
            }
            else
            {
                ToastService.ShowError($"Failed to set up webhook in {Name}.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task Disconnect()
    {
        _isBusy = true;
        StateHasChanged();

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var arrConfig = context.Configs.GetOrDefault<ArrConfig>(ConfigKey);

            var existing = await ArrApi.FindMuxarrNotification(arrConfig);
            if (existing == null)
            {
                ToastService.ShowInfo($"No Muxarr webhook found in {Name}.");
                await StatusChanged.InvokeAsync(ConnectStatus.Disconnected);
                return;
            }

            var success = await ArrApi.DeleteWebhookNotification(arrConfig, existing.Id);
            if (success)
            {
                ToastService.ShowSuccess($"Webhook removed from {Name}.");
                await StatusChanged.InvokeAsync(ConnectStatus.Disconnected);
            }
            else
            {
                ToastService.ShowError($"Failed to remove webhook from {Name}.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    public enum ConnectStatus { Connected, Disconnected, NotConfigured }

    public static async Task<ConnectStatus> GetStatus(ArrApiClient arrApi, ArrConfig arrConfig)
    {
        if (string.IsNullOrWhiteSpace(arrConfig.Url) || string.IsNullOrWhiteSpace(arrConfig.ApiKey))
        {
            return ConnectStatus.NotConfigured;
        }

        var existing = await arrApi.FindMuxarrNotification(arrConfig);
        return existing != null ? ConnectStatus.Connected : ConnectStatus.Disconnected;
    }

    private static string FormatStatus(ConnectStatus status) => status switch
    {
        ConnectStatus.Connected => "Connected",
        ConnectStatus.Disconnected => "Disconnected",
        ConnectStatus.NotConfigured => "Not Configured",
        _ => status.ToString()
    };
}
