@using Muxarr.Core.Api.Models
@using Muxarr.Core.Config
@using Muxarr.Core.Utilities

<p class="text-muted">Use the API to integrate Muxarr with dashboards and external tools.</p>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-bar-chart me-2"></i>GET /api/stats</div>
            <div class="card-body">
                <p class="text-muted small mb-2">Request</p>
                <CodeBlock Value="@CurlExample" />
                <p class="text-muted small mb-2 mt-3">Response</p>
                <CodeBlock Value="@ResponseExample" />
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-layout-text-sidebar me-2"></i>Homepage Widget</div>
            <div class="card-body">
                <p class="text-muted small mb-2">
                    Add this to your <a href="https://gethomepage.dev/widgets/services/customapi/" target="_blank">Homepage</a> <code>services.yaml</code>:
                </p>
                <CodeBlock Value="@HomepageExample" />
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }

    private string _apiKey = string.Empty;
    private string _baseUrl = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        var config = context.Configs.GetOrDefault<WebhookConfig>();
        _apiKey = config.ApiKey;
        _baseUrl = string.IsNullOrWhiteSpace(config.MuxarrUrl)
            ? "http://<muxarr-host>:8183"
            : config.MuxarrUrl.TrimEnd('/');
    }

    private string StatsUrl => $"{_baseUrl}/api/stats";

    private string CurlExample =>
        $"curl -H \"X-Api-Key: {_apiKey}\" {StatsUrl}";

    private static readonly Lazy<string> ExampleJson = new(() =>
    {
        var options = JsonHelper.JsonDotNetDefaults;
        options.WriteIndented = true;
        options.PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase;
        return System.Text.Json.JsonSerializer.Serialize(StatsResponse.Example, options);
    });

    private string ResponseExample => ExampleJson.Value;

    private string HomepageExample =>
$@"- Muxarr:
    icon: mdi-movie-filter
    href: {_baseUrl}
    widget:
      type: customapi
      url: {StatsUrl}
      headers:
        X-Api-Key: {_apiKey}
      mappings:
        - field: totalFiles
          label: Library
          format: number
        - field: activeConversions
          label: Active
          format: number
        - field: completedConversions
          label: Completed
          format: number
        - field: spaceSavedBytes
          label: Saved
          format: bytes";
}
