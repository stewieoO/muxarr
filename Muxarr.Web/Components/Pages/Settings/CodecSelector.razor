<TagSelector TItem="SubtitleCodec" SelectedItems="SelectedItems" OnSearchInput="OnSearchInput" ShowListOnFocus="true">
    <TagTemplate>@context.DisplayName()</TagTemplate>
    <ListTemplate>@context.DisplayName()</ListTemplate>
</TagSelector>

@code {
    [Parameter] [EditorRequired] public required List<SubtitleCodec> SelectedItems { get; set; }

    private Task<List<SubtitleCodec>> OnSearchInput(string query)
    {
        var results = SubtitleCodecExtensions.SelectableValues
            .Where(c => !SelectedItems.Contains(c))
            .Where(c => string.IsNullOrEmpty(query)
                        || c.DisplayName().Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();

        return Task.FromResult(results);
    }

}
