@using Microsoft.AspNetCore.Identity
@using Muxarr.Core.Config

<p class="text-muted">Configure authentication and API access.</p>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-person-lock me-2"></i>Login</h5>
                <p class="text-muted small">When a username and password are set, login is required to access the web UI. Leave empty for open access.</p>

                @if (IsConfigured)
                {
                    <div class="alert alert-info py-2 small mb-3">
                        Authentication is enabled for user <strong>@CurrentUsername</strong>.
                    </div>
                }

                <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="Model.Username" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@(IsConfigured ? "New Password" : "Password")</label>
                        <InputText type="password" class="form-control" @bind-Value="Model.Password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <InputText type="password" class="form-control" @bind-Value="Model.ConfirmPassword" />
                    </div>

                    <ValidationSummary />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-save me-1"></i>@(IsConfigured ? "Update" : "Enable")
                        </button>
                        @if (IsConfigured)
                        {
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="HandleDisable">
                                <i class="bi bi-shield-x me-1"></i>Disable
                            </button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-key me-2"></i>API Key</h5>
                <p class="text-muted small">Used to authenticate API and webhook requests. Pass via <code>X-Api-Key</code> header or <code>?apikey=</code> query parameter.</p>

                <div class="mb-3">
                    <div class="input-group">
                        <input type="text" class="form-control" value="@_apiKey" readonly />
                        <ToolTip Tip="Regenerate API key">
                            <button type="button" class="btn btn-outline-secondary" @onclick="RegenerateApiKey">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </ToolTip>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [Inject] public required IModalService ModalService { get; set; }

    private static readonly PasswordHasher<string> Hasher = new();

    private AuthFormModel Model { get; set; } = new();
    private bool IsConfigured { get; set; }
    private string CurrentUsername { get; set; } = string.Empty;
    private string _apiKey = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadState();
    }

    private async Task LoadState()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        var config = context.Configs.Get<AuthConfig>(AuthConfig.Key);
        IsConfigured = config != null;
        CurrentUsername = config?.Username ?? string.Empty;
        Model.Username = CurrentUsername;

        var webhookConfig = context.Configs.GetOrDefault<WebhookConfig>();
        _apiKey = webhookConfig.ApiKey;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(Model.Username))
        {
            ToastService.ShowError("Username is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(Model.Password))
        {
            ToastService.ShowError("Password is required.");
            return;
        }

        if (Model.Password != Model.ConfirmPassword)
        {
            ToastService.ShowError("Passwords do not match.");
            return;
        }

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var config = new AuthConfig
            {
                Username = Model.Username.Trim(),
                PasswordHash = Hasher.HashPassword(Model.Username, Model.Password)
            };
            context.Configs.Set(config, AuthConfig.Key);
            await context.SaveChangesAsync();

            Model.Password = string.Empty;
            Model.ConfirmPassword = string.Empty;

            await LoadState();
            ToastService.ShowSuccess("Authentication settings saved.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to save: {ex.Message}");
        }
    }

    private async Task HandleDisable()
    {
        var confirmed = await ModalService.ShowConfirm(
            "This will remove login protection. Anyone with access to the URL will be able to use Muxarr, " +
            "including modifying settings and processing files.",
            "Disable authentication?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            context.Configs.Set<AuthConfig>(null, AuthConfig.Key);
            await context.SaveChangesAsync();

            Model = new AuthFormModel();
            await LoadState();
            ToastService.ShowSuccess("Authentication disabled.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to disable: {ex.Message}");
        }
    }

    private async Task RegenerateApiKey()
    {
        var confirmed = await ModalService.ShowConfirm(
            "Regenerating the API key will invalidate all existing connections, " +
            "including *Arr webhooks and any external integrations (e.g. Homepage).",
            "Regenerate API Key?");
        if (!confirmed)
        {
            return;
        }

        _apiKey = Guid.NewGuid().ToString("N");

        await using var context = await ContextFactory.CreateDbContextAsync();
        var config = context.Configs.GetOrDefault<WebhookConfig>();
        config.ApiKey = _apiKey;
        context.Configs.Set(config);
        await context.SaveChangesAsync();

        ToastService.ShowInfo("New API key generated. Reconnect your *Arr instances and external integrations.");
    }

    private class AuthFormModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
