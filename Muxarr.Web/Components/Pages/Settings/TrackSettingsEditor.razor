<div>
    @* --- Track Removal --- *@
    <div class="mb-3 form-check form-switch">
        <InputCheckbox id="@($"strip{TrackTypeLabel}Tracks")" class="form-check-input" @bind-Value="Settings.Enabled"
                       @bind-Value:after="OnEnabledToggled"/>
        <label class="form-check-label" for="@($"strip{TrackTypeLabel}Tracks")">Remove
            unwanted @TrackTypeLabel.ToLower() tracks</label>
    </div>

    @if (Settings.Enabled)
    {
        <div class="ms-3 ps-3 border-start mb-3">
            <div class="mb-3">
                <label class="form-label mb-1">Allowed @TrackType Languages</label>
                <LanguagePriorityEditor Languages="Settings.AllowedLanguages"
                                        TrackType="TrackType"/>
                <small class="form-text text-muted">
                    Drag to set priority. Click <i class="bi bi-gear"></i> for per-language settings like track limits.
                    This order is used by the default track and track order options below.
                </small>
            </div>

            <div class="mb-3 form-check form-switch">
                <InputCheckbox id="@($"removeCommentary{TrackTypeLabel}")" class="form-check-input"
                               @bind-Value="Settings.RemoveCommentary"/>
                <label class="form-check-label" for="@($"removeCommentary{TrackTypeLabel}")">Remove
                    Commentary @TrackTypeLabel</label>
                <small class="form-text text-muted d-block">Removes commentary @(TrackTypeLabel.ToLower())s. Keeps them
                    if they're the only option for that language.</small>
            </div>

            <div class="mb-3 form-check form-switch">
                <InputCheckbox id="@($"removeImpaired{TrackTypeLabel}")" class="form-check-input"
                               @bind-Value="Settings.RemoveImpaired"/>
                <label class="form-check-label" for="@($"removeImpaired{TrackTypeLabel}")">Remove SDH /
                    Accessibility @TrackTypeLabel</label>
                <small class="form-text text-muted d-block">Removes @(TrackTypeLabel.ToLower())s for hearing or visually
                    impaired viewers (SDH, closed captions, audio descriptions). Keeps them if they're the only
                    option.</small>
            </div>

            <div class="mb-3 form-check form-switch">
                <InputCheckbox id="@($"assumeUnd{TrackTypeLabel}")" class="form-check-input"
                               @bind-Value="Settings.AssumeUndeterminedIsOriginal"/>
                <label class="form-check-label" for="@($"assumeUnd{TrackTypeLabel}")">Assume undetermined language is
                    original language</label>
                <small class="form-text text-muted d-block">When a file has exactly
                    one @(TrackTypeLabel.ToLower()) track with no language set, this treats it as the original language
                    detected by Sonarr/Radarr. Does not apply when there are multiple tracks. Alternatively, add
                    "Undetermined" to the allowed languages above to always keep unlabeled tracks.</small>
            </div>

            @if (!IsAudio)
            {
                <div class="mb-3 form-check form-switch">
                    <InputCheckbox id="@($"excludeCodecs{TrackTypeLabel}")" class="form-check-input"
                                   @bind-Value="Settings.ExcludeCodecs"/>
                    <label class="form-check-label" for="@($"excludeCodecs{TrackTypeLabel}")">Exclude Subtitle
                        Codecs</label>
                    <small class="form-text text-muted d-block">Remove subtitle tracks that match specific codecs during
                        conversion. Useful for dropping image-based formats like PGS or VobSub.</small>
                </div>

                @if (Settings.ExcludeCodecs)
                {
                    <div class="mb-3 ms-4">
                        <CodecSelector SelectedItems="Settings.ExcludedCodecs"/>
                    </div>
                }
            }
        </div>
    }

    @* --- Default Track --- *@
    <div class="mb-3">
        <label class="form-label mb-1">Default track</label>
        <select class="form-select form-select-sm" style="max-width: 320px;"
                value="@Settings.DefaultStrategy"
                @onchange="e => Settings.DefaultStrategy = Enum.Parse<DefaultTrackStrategy>(e.Value?.ToString() ?? nameof(DefaultTrackStrategy.DontChange))">
            <option value="@nameof(DefaultTrackStrategy.DontChange)">Don't change (preserve original)</option>
            <option value="@nameof(DefaultTrackStrategy.SpecCompliant)">Spec compliant</option>
            <option value="@nameof(DefaultTrackStrategy.ForceFirstLanguage)"
                    disabled="@(!HasLanguagePriority)">
                Always prefer first language@(!HasLanguagePriority ? " (set up allowed languages first)" : "")
            </option>
        </select>
        <small class="form-text text-muted d-block">
            @switch (Settings.DefaultStrategy)
            {
                case DefaultTrackStrategy.SpecCompliant:
                    <text>Commentary and accessibility tracks are marked as non-default. Your player picks from the
                        rest.</text>
                    break;
                case DefaultTrackStrategy.ForceFirstLanguage:
                    <text>Finds the best matching language based on your priority list and marks it as default. For
                        players without language settings.</text>
                    break;
                default:
                    <text>Original default flags from the source file are preserved.</text>
                    break;
            }
        </small>
    </div>

    @* --- Track Order --- *@
    <div class="mb-3">
        <label class="form-label mb-1">Track order</label>
        <select class="form-select form-select-sm" style="max-width: 320px;"
                value="@Settings.ReorderStrategy"
                @onchange="e => Settings.ReorderStrategy = Enum.Parse<TrackReorderStrategy>(e.Value?.ToString() ?? nameof(TrackReorderStrategy.DontReorder))">
            <option value="@nameof(TrackReorderStrategy.DontReorder)">Don't reorder (preserve original)</option>
            <option value="@nameof(TrackReorderStrategy.Alphabetical)">Alphabetical by language</option>
            <option value="@nameof(TrackReorderStrategy.MatchLanguagePriority)"
                    disabled="@(!HasLanguagePriority)">
                Match language priority@(!HasLanguagePriority ? " (set up allowed languages first)" : "")
            </option>
        </select>
        <small class="form-text text-muted d-block">
            @switch (Settings.ReorderStrategy)
            {
                case TrackReorderStrategy.Alphabetical:
                    <text>Tracks are sorted A-Z by language. Best quality first within each language. Requires
                        remux.</text>
                    break;
                case TrackReorderStrategy.MatchLanguagePriority:
                    <text>
                        Tracks are sorted to match your priority list. Best quality first within each language. Requires
                        remux.</text>
                    break;
                default:
                    <text>Original track order from the source file is preserved.</text>
                    break;
            }
        </small>
    </div>

    @* --- Track Names --- *@
    <div class="mb-3 form-check form-switch">
        <InputCheckbox id="@($"standardize{TrackTypeLabel}")" class="form-check-input"
                       @bind-Value="Settings.StandardizeTrackNames" @bind-Value:after="OnStandardizeToggled"/>
        <label class="form-check-label" for="@($"standardize{TrackTypeLabel}")">Standardize @TrackTypeLabel Track
            Names</label>
        <small class="form-text text-muted d-block">Rename @(TrackTypeLabel.ToLower()) tracks during conversion using a
            template.</small>
    </div>

    @if (Settings.StandardizeTrackNames)
    {
        <div class="mb-3 ms-4">
            <div class="option-label text-muted small mb-1">Default template</div>
            <InputText id="@($"trackNameTemplate{TrackTypeLabel}")" class="form-control form-control-sm"
                       @bind-Value="Settings.TrackNameTemplate"/>
            <small class="form-text text-muted d-block">
                Placeholders: <code>{language}</code>, <code>{nativelanguage}</code>, <code>{codec}</code>,
                @if (IsAudio)
                {
                    <code>{channels}</code>
                    <text>,</text>
                }
                <code>{trackname}</code>,
                <code>{hi}</code>, <code>{forced}</code>, <code>{commentary}</code>, <code>{visualimpaired}</code>,
                <code>{original}</code>, <code>{flags}</code>.
                Leave empty to clear all track names.
            </small>

            @if (!string.IsNullOrWhiteSpace(Settings.TrackNameTemplate))
            {
                <div class="mt-2 text-muted small">
                    <i class="bi bi-eye me-1"></i>Preview:
                    <div class="mt-1">
                        @foreach (var track in GetPreviewTracks())
                        {
                            var template = Settings.ResolveTemplate(track);
                            var resolved = track.ApplyTrackNameTemplate(template);
                            var isOverride = template != Settings.TrackNameTemplate;
                            <div>
                                <code>@(resolved ?? "(empty)")</code>
                                @if (isOverride)
                                {
                                    <span class="text-info ms-1" style="font-size: 0.75rem;">override</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="mt-3">
                <a class="text-decoration-none small" data-bs-toggle="collapse"
                   href="#@($"flagOverrides{TrackTypeLabel}")" role="button">
                    <i class="bi bi-sliders me-1"></i>Flag-specific overrides
                </a>
            </div>

            <div class="collapse @(_hasOverrides ? "show" : "")" id="@($"flagOverrides{TrackTypeLabel}")">
                <div class="d-flex flex-column gap-2 mt-2 ms-2 border-start ps-3">
                    @foreach (var flag in TrackFlagExtensions.All)
                    {
                        var currentFlag = flag;
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge text-bg-secondary" style="width: 110px;">
                                <i class="bi @FlagIcon(flag) me-1"></i>@flag.GetDisplayName()
                            </span>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   style="max-width: 300px;"
                                   placeholder="(uses default)"
                                   value="@GetOverride(currentFlag)"
                                   @onchange="e => SetOverride(currentFlag, e.Value?.ToString())"/>
                        </div>
                    }
                </div>
                <small class="text-muted d-block mt-2">Leave blank to use the default template. First matching flag
                    wins.</small>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] [EditorRequired] public TrackSettings Settings { get; set; } = default!;

    [Parameter] [EditorRequired] public MediaTrackType TrackType { get; set; }

    private string TrackTypeLabel => TrackType == MediaTrackType.Audio ? "Audio" : "Subtitle";
    private bool IsAudio => TrackType == MediaTrackType.Audio;
    private bool HasLanguagePriority => Settings.AllowedLanguages.Count > 0;
    private string DefaultTemplate => IsAudio ? "{language} {channels}" : "{language}";

    private string PreviewLanguage =>
        Settings.AllowedLanguages.Count > 0 ? Settings.AllowedLanguages[0].Language.Name : "English";

    private string? SecondLanguage =>
        Settings.AllowedLanguages.Count > 1 ? Settings.AllowedLanguages[1].Language.Name : null;

    private List<TrackSnapshot> GetPreviewTracks()
    {
        if (IsAudio)
        {
            var tracks = new List<TrackSnapshot>
            {
                new() { Type = MediaTrackType.Audio, LanguageName = PreviewLanguage, Codec = "TrueHD", AudioChannels = 8, IsOriginal = true },
                new() { Type = MediaTrackType.Audio, LanguageName = PreviewLanguage, Codec = "E-AC-3", AudioChannels = 6 },
                new() { Type = MediaTrackType.Audio, LanguageName = PreviewLanguage, Codec = "AAC", AudioChannels = 2, IsCommentary = true }
            };
            if (SecondLanguage != null)
            {
                tracks.Add(new TrackSnapshot { Type = MediaTrackType.Audio, LanguageName = SecondLanguage, Codec = "E-AC-3", AudioChannels = 6 });
            }

            return tracks;
        }
        else
        {
            var tracks = new List<TrackSnapshot>
            {
                new() { Type = MediaTrackType.Subtitles, LanguageName = PreviewLanguage, Codec = "SRT" },
                new() { Type = MediaTrackType.Subtitles, LanguageName = PreviewLanguage, Codec = "SRT", IsHearingImpaired = true },
                new() { Type = MediaTrackType.Subtitles, LanguageName = PreviewLanguage, Codec = "PGS", IsForced = true }
            };
            if (SecondLanguage != null)
            {
                tracks.Add(new TrackSnapshot { Type = MediaTrackType.Subtitles, LanguageName = SecondLanguage, Codec = "SRT" });
            }

            return tracks;
        }
    }

    private bool _hasOverrides => Settings.TrackNameOverrides.Any(kv => !string.IsNullOrEmpty(kv.Value));

    private static string FlagIcon(TrackFlag flag)
    {
        return flag switch
        {
            TrackFlag.HearingImpaired => "bi-ear",
            TrackFlag.Forced => "bi-lock",
            TrackFlag.Commentary => "bi-chat-quote",
            TrackFlag.VisualImpaired => "bi-eye",
            _ => "bi-question-circle"
        };
    }

    private string GetOverride(TrackFlag flag)
    {
        return Settings.TrackNameOverrides.TryGetValue(flag, out var value) ? value : "";
    }

    private void SetOverride(TrackFlag flag, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            Settings.TrackNameOverrides.Remove(flag);
        }
        else
        {
            Settings.TrackNameOverrides[flag] = value;
        }
    }

    private void OnEnabledToggled()
    {
        if (Settings.Enabled && Settings.AllowedLanguages.Count == 0 && IsAudio)
        {
            Settings.AllowedLanguages.Add(new LanguagePreference(IsoLanguage.OriginalLanguage));
        }
    }

    private void OnStandardizeToggled()
    {
        if (Settings.StandardizeTrackNames && string.IsNullOrEmpty(Settings.TrackNameTemplate))
        {
            Settings.TrackNameTemplate = DefaultTemplate;
        }
    }

}
