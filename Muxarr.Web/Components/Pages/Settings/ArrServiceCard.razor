@using Muxarr.Core.Api
@using Muxarr.Data.Entities
<div class="border rounded p-4">
    <div class="d-flex flex-wrap align-items-center gap-1 mb-3">
        <i class="bi @IconClass text-primary me-2"></i>
        <h5 class="mb-0">@Service.Name</h5>
        @if (_isConnected != null)
        {
            <span class="badge @(_isConnected.Value ? "text-bg-success" : "text-bg-danger")">
                <i class="bi @(_isConnected.Value ? "bi-check-circle" : "bi-x-circle") me-1"></i>@(_isConnected.Value ? "Connected" : "Not Connected")
            </span>
        }
        @if (_isWebhookConnected != null)
        {
            <span class="badge @(_isWebhookConnected.Value ? "text-bg-success" : "text-bg-secondary")">
                <i class="bi @(_isWebhookConnected.Value ? "bi-link-45deg" : "bi-link") me-1"></i>@(_isWebhookConnected.Value ? "Webhook Active" : "No Webhook")
            </span>
        }
    </div>

    <div class="mb-3">
        <label for="@($"name-{Service.Id}")" class="form-label">Name</label>
        <InputText id="@($"name-{Service.Id}")" class="form-control" @bind-Value="Service.Name"/>
    </div>

    <div class="mb-3">
        <label for="@($"url-{Service.Id}")" class="form-label">URL</label>
        <InputText id="@($"url-{Service.Id}")" class="form-control" @bind-Value="Service.Url"/>
        <small class="form-text text-muted">Example: @Example</small>
    </div>

    <div class="mb-3">
        <label for="@($"apiKey-{Service.Id}")" class="form-label">API Key</label>
        <InputText id="@($"apiKey-{Service.Id}")" class="form-control" @bind-Value="Service.ApiKey"/>
        <small class="form-text text-muted">Found in @TypeName > Settings > General > Security</small>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="TestConnection" disabled="@_isBusy">
            @if (_isBusy)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            <i class="bi bi-plug me-1"></i>Test Connection
        </button>

        <button type="button" class="btn btn-outline-success btn-sm" @onclick="ConnectWebhook" disabled="@_isBusy">
            <i class="bi bi-link-45deg me-1"></i>Connect Webhook
        </button>
        @if (_isWebhookConnected == true)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DisconnectWebhook"
                    disabled="@_isBusy">
                <i class="bi bi-x-circle me-1"></i>Disconnect
            </button>
        }

        @if (OnDelete.HasDelegate)
        {
            <button type="button" class="btn btn-outline-danger btn-sm ms-auto" @onclick="OnDelete"
                    disabled="@_isBusy">
                <i class="bi bi-trash me-1"></i>Remove
            </button>
        }
    </div>
</div>

@code {
    private string TypeName => Service.Type == ExternalServiceType.Sonarr ? "Sonarr" : "Radarr";
    private string Example => Service.Type == ExternalServiceType.Sonarr
        ? "http://sonarr.instance:8989"
        : "http://radarr.instance:7878";
    private string IconClass => Service.Type == ExternalServiceType.Sonarr ? "bi-tv" : "bi-film";

    private bool _isBusy;
    private bool? _isConnected;
    private bool? _isWebhookConnected;

    [Parameter] [EditorRequired] public required ExternalService Service { get; set; }
    [Parameter] public Func<string>? GetWebhookUrl { get; set; }
    [Parameter] public Func<Task>? AutoSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    [Inject] public required ArrApiClient ArrApi { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Service.Url) || string.IsNullOrWhiteSpace(Service.ApiKey))
        {
            return;
        }

        try
        {
            _isConnected = await ArrApi.CanConnect(Service);

            if (_isConnected == true)
            {
                var notification = await ArrApi.FindMuxarrNotification(Service);
                _isWebhookConnected = notification != null;
            }
        }
        catch
        {
            _isConnected = false;
        }
    }

    private async Task TestConnection()
    {
        if (string.IsNullOrWhiteSpace(Service.Url) || string.IsNullOrWhiteSpace(Service.ApiKey))
        {
            ToastService.ShowWarning($"Please enter a URL and API key for {Service.Name}.");
            return;
        }

        _isBusy = true;
        _isConnected = null;
        StateHasChanged();

        try
        {
            if (AutoSave != null)
            {
                await AutoSave();
            }

            Service.Url = Service.Url.SanitizeUrl();
            _isConnected = await ArrApi.CanConnect(Service);

            if (_isConnected == true)
            {
                ToastService.ShowSuccess($"{Service.Name} connection successful!");

                var notification = await ArrApi.FindMuxarrNotification(Service);
                _isWebhookConnected = notification != null;
            }
            else
            {
                ToastService.ShowError($"Could not connect to {Service.Name}. Check URL and API key.");
            }
        }
        catch
        {
            _isConnected = false;
            ToastService.ShowError($"Could not connect to {Service.Name}. Check URL and API key.");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ConnectWebhook()
    {
        _isBusy = true;
        StateHasChanged();

        try
        {
            if (AutoSave != null)
            {
                await AutoSave();
            }

            var webhookUrl = GetWebhookUrl?.Invoke() ?? "";
            if (string.IsNullOrWhiteSpace(webhookUrl) || webhookUrl.Contains("<muxarr-host>"))
            {
                ToastService.ShowWarning("Please set the Muxarr URL first.");
                return;
            }

            await using var context = await ContextFactory.CreateDbContextAsync();
            var svc = await context.ExternalServices.FindAsync(Service.Id);

            if (svc == null || string.IsNullOrWhiteSpace(svc.Url) || string.IsNullOrWhiteSpace(svc.ApiKey))
            {
                ToastService.ShowWarning($"{Service.Name} is not configured. Enter the URL and API key first.");
                return;
            }

            var existing = await ArrApi.FindMuxarrNotification(svc);
            var success = existing != null
                ? await ArrApi.UpdateWebhookNotification(svc, existing, webhookUrl)
                : await ArrApi.CreateWebhookNotification(svc, webhookUrl);

            if (success)
            {
                _isWebhookConnected = true;
                ToastService.ShowSuccess($"Webhook {(existing != null ? "updated" : "created")} in {Service.Name}!");
            }
            else
            {
                ToastService.ShowError($"Failed to set up webhook in {Service.Name}.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DisconnectWebhook()
    {
        _isBusy = true;
        StateHasChanged();

        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            var svc = await context.ExternalServices.FindAsync(Service.Id);

            if (svc == null)
            {
                return;
            }

            var existing = await ArrApi.FindMuxarrNotification(svc);
            if (existing == null)
            {
                _isWebhookConnected = false;
                ToastService.ShowInfo($"No Muxarr webhook found in {Service.Name}.");
                return;
            }

            var success = await ArrApi.DeleteWebhookNotification(svc, existing.Id);
            if (success)
            {
                _isWebhookConnected = false;
                ToastService.ShowSuccess($"Webhook removed from {Service.Name}.");
            }
            else
            {
                ToastService.ShowError($"Failed to remove webhook from {Service.Name}.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

}
