@page "/conversions"
@using Muxarr.Web.Components.Pages.Library
@inherits SelectablePaginatedListComponent<MediaConversion>
@attribute [StreamRendering]

<PageTitle>@TitleHelper.GetTitle("Conversions")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4 mux-page-header">
        <h2 class="mb-0">
            <i class="bi bi-arrow-repeat me-2"></i>Conversions
        </h2>
        <div class="btn-group btn-group-sm">
            <button class="btn @(MediaConverter.IsPaused ? "btn-success" : "btn-warning")"
                    @onclick="OnTogglePause" title="@(MediaConverter.IsPaused ? "Resume queue" : "Pause queue")">
                <i class="bi @(MediaConverter.IsPaused ? "bi-play-fill" : "bi-pause-fill") me-1"></i>
                @(MediaConverter.IsPaused ? "Resume" : "Pause")
            </button>
            @if (_queuedCount > 0)
            {
                <button class="btn btn-outline-danger" @onclick="OnClearQueue" title="Clear all queued conversions">
                    <i class="bi bi-trash me-1"></i>Clear Queue
                </button>
            }
        </div>
    </div>

    @if (MediaConverter.IsPaused)
    {
        <Alert Type="warning">
            The conversion queue is paused. New conversions will not start until resumed.
        </Alert>
    }

    @if (_currentConversion != null || _queuedCount > 0)
    {
        <div class="card border-primary mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-arrow-repeat me-2"></i>Active Conversions
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                        <tr>
                            <th>File</th>
                            <th>State</th>
                            <th>Progress</th>
                            <th>Queued</th>
                            <th class="text-center" style="width: 50px"></th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (_currentConversion != null)
                        {
                            <tr>
                                <td>
                                    <a href="/conversions/@_currentConversion.Id">
                                        <span class="small">@_currentConversion.Name</span>
                                    </a>
                                </td>
                                <td>
                                    <ConversionStateBadge Conversion="_currentConversion"/>
                                </td>
                                <td>
                                    <ConversionProgressBar Conversion="_currentConversion"/>
                                </td>
                                <td>
                                    <TimeAgo DateTime="_currentConversion.CreatedDate"/>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-outline-danger btn-sm" title="Cancel"
                                            @onclick="OnCancelCurrent">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @foreach (var conversion in _nextQueued)
                        {
                            <tr>
                                <td>
                                    <a href="/conversions/@conversion.Id">
                                        <span class="small">@conversion.Name</span>
                                    </a>
                                </td>
                                <td>
                                    <ConversionStateBadge Conversion="conversion"/>
                                </td>
                                <td>
                                    <ConversionProgressBar Conversion="conversion"/>
                                </td>
                                <td>
                                    <TimeAgo DateTime="conversion.CreatedDate"/>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-outline-danger btn-sm" title="Cancel"
                                            @onclick="() => OnCancelQueued(conversion)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (_queuedCount > QueuePreviewSize)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-2">
                                    <i class="bi bi-three-dots me-1"></i>
                                    and @(_queuedCount - QueuePreviewSize) more queued
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="row mb-3 g-2 mux-filter-row">
        @if (SelectedItems.Count > 0)
        {
            <div class="col-auto">
                <button class="btn btn-danger btn-sm" @onclick="OnDeleteSelected">
                    <i class="bi bi-trash me-1"></i>Delete @SelectedItems.Count selected
                </button>
            </div>
        }
        <div class="col">
            <SearchBar Parent="this"></SearchBar>
        </div>
        <div class="col-auto d-flex justify-content-center gap-2 align-items-center">
            <div class="btn-group btn-group-sm">
                @foreach (var state in _stateOptions)
                {
                    <button class="btn @(state == _stateFilter ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => FilterByState(state)">
                        @state
                    </button>
                }
            </div>
        </div>
        <div class="col-auto d-flex justify-content-center gap-2 align-items-center">
            <ResetFilters Parent="this"></ResetFilters>
        </div>
        <div class="col-auto">
            <ItemsPerPage Parent="this"/>
        </div>
    </div>
    <Loader IsLoading="IsLoading">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                <tr>
                    <th>
                        <SelectAllCheckbox TType="MediaConversion" Parent="this"/>
                    </th>
                    <th>
                        <SortHeader Parent="this" SortProperty="Name">
                            File
                        </SortHeader>
                    </th>
                    <th>State</th>
                    <th>
                        <SortHeader Parent="this" SortProperty="Progress">
                            Progress
                        </SortHeader>
                    </th>
                    <th>
                        <SortHeader Parent="this" SortProperty="SizeDifference">
                            Size Reduction
                        </SortHeader>
                    </th>
                    <th>
                        <SortHeader Parent="this" SortProperty="CreatedDate">
                            Queued
                        </SortHeader>
                    </th>
                    <th>
                        <SortHeader Parent="this" SortProperty="StartedDate">
                            Started
                        </SortHeader>
                    </th>
                    <th>Tracks Before</th>
                    <th>Tracks After</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var conversion in Items)
                {
                    <tr>
                        <td>
                            <SelectionCheckbox TType="MediaConversion" Parent="this" Item="conversion"/>
                        </td>
                        <td>
                            <a href="/conversions/@conversion.Id">
                            <span class="small">
                                @(conversion.Name)
                            </span>
                            </a>
                        </td>
                        <td>
                            <ConversionStateBadge Conversion="conversion"/>
                        </td>
                        <td>
                            <ConversionProgressBar Conversion="conversion"/>
                        </td>
                        <td>
                            @if (conversion.State == ConversionState.Completed)
                            {
                                <span>@conversion.GetSizeChangePercentage()</span>
                            }
                        </td>
                        <td>
                            <TimeAgo DateTime="conversion.CreatedDate"/>
                        </td>
                        <td>
                            @if (conversion.StartedDate.HasValue)
                            {
                                <TimeAgo DateTime="conversion.StartedDate.Value"/>
                            }
                        </td>
                        <td>
                            <MediaTrackLabels Tracks="conversion.TracksBefore"></MediaTrackLabels>
                        </td>
                        <td>
                            <MediaTrackLabels Tracks="conversion.TracksAfter"></MediaTrackLabels>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <Pagination Parent="this"/>
    </Loader>
</div>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }
    [Inject] public required MediaConverterService MediaConverter { get; set; }
    [Inject] public required IModalService ModalService { get; set; }
    [Inject] public required IToastService ToastService { get; set; }

    [Filter] private string _stateFilter = "All";

    private const int QueuePreviewSize = 5;
    private readonly string[] _stateOptions = ["All", "New", "Processing", "Completed", "Failed"];

    private MediaConversion? _currentConversion;
    private List<MediaConversion> _nextQueued = [];
    private int _queuedCount;

    protected override void OnInitialized()
    {
        CurrentSortProperty = "CreatedDate";
        IsAscending = false;
    }

    protected override async Task OnInitializedAsync()
    {
        MediaConverter.ConverterStateChanged += OnConverterStateChanged;
        MediaConverter.QueueStateChanged += OnQueueStateChanged;
        await LoadFilters();
    }

    protected override async Task UpdateListCore()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();

        _currentConversion = await context.MediaConversions
            .Include(c => c.MediaFile)
            .FirstOrDefaultAsync(c => c.State == ConversionState.Processing);

        _queuedCount = await context.MediaConversions
            .CountAsync(c => c.State == ConversionState.New);

        _nextQueued = await context.MediaConversions
            .Include(c => c.MediaFile)
            .Where(c => c.State == ConversionState.New)
            .OrderBy(c => c.CreatedDate)
            .Take(QueuePreviewSize)
            .ToListAsync();

        // Paginated history
        var query = context.MediaConversions
            .Include(c => c.MediaFile)
            .AsQueryable();

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            query = query.Where(c =>
                (c.MediaFile != null &&
                 EF.Functions.Like(c.MediaFile.Path, $"%{SearchTerm}%")) ||
                EF.Functions.Like(c.Name, $"%{SearchTerm}%")
            );
        }

        if (_stateFilter != "All" && Enum.TryParse<ConversionState>(_stateFilter, out var state))
        {
            query = query.Where(c => c.State == state);
        }

        var result = await query.Sort(CurrentSortProperty, IsAscending).FindPagedAsync(Page, PageSize, true);
        TotalItems = result.Total;
        TotalPages = result.TotalPages;
        Items = await result.Data.ToListAsync().ConfigureAwait(false);
    }

    private async Task FilterByState(string state)
    {
        _stateFilter = state;
        Page = 1;
        await UpdateList();
    }

    private void OnTogglePause()
    {
        MediaConverter.TogglePause();
        StateHasChanged();
    }

    private async Task OnCancelCurrent()
    {
        if (!await ModalService.ShowConfirm("Are you sure you want to cancel the current conversion?", "Cancel Conversion"))
        {
            return;
        }

        MediaConverter.CancelCurrentConversion();
    }

    private async Task OnCancelQueued(MediaConversion conversion)
    {
        if (!await ModalService.ShowConfirm($"Are you sure you want to remove '{conversion.Name}' from the queue?", "Remove from Queue"))
        {
            return;
        }

        await MediaConverter.CancelQueuedConversion(conversion.Id);
        await UpdateList();
    }

    private async Task OnClearQueue()
    {
        if (!await ModalService.ShowConfirm("Are you sure you want to remove all queued conversions? These have not started yet and will be deleted.", "Clear Queue"))
        {
            return;
        }

        await MediaConverter.ClearQueue();
        await UpdateList();
    }

    private async Task OnDeleteSelected()
    {
        var deletable = SelectedItems.Where(c => c.State != ConversionState.Processing).ToList();
        if (deletable.Count == 0)
        {
            return;
        }

        if (!await ModalService.ShowConfirm(
                $"Are you sure you want to delete {deletable.Count} conversion(s)? This will affect conversion statistics.", "Delete Conversions"))
        {
            return;
        }

        var ids = deletable.Select(c => c.Id).ToList();
        await using var context = await ContextFactory.CreateDbContextAsync();
        await context.MediaConversions.Where(c => ids.Contains(c.Id)).ExecuteDeleteAsync();
        SelectedItems.Clear();
        await UpdateList();
        ToastService.ShowSuccess($"Deleted {deletable.Count} conversion(s).");
    }

    private void OnQueueStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnConverterStateChanged(ConverterProgressEvent e)
    {
        _ = InvokeAsync(async () =>
        {
            // Progress tick: update in-memory only (hot path, fires every ~1%)
            if (_currentConversion != null && e.Conversion.Id == _currentConversion.Id
                                           && e.Conversion.State == ConversionState.Processing)
            {
                _currentConversion.Progress = e.Conversion.Progress;

                var item = Items.FirstOrDefault(x => x.Id == e.Conversion.Id);
                if (item != null)
                {
                    item.Progress = e.Conversion.Progress;
                }

                StateHasChanged();
                return;
            }

            // State transition (started, completed, failed): refresh from DB
            await UpdateList();
            StateHasChanged();
        });
    }

    public override void Dispose()
    {
        MediaConverter.ConverterStateChanged -= OnConverterStateChanged;
        MediaConverter.QueueStateChanged -= OnQueueStateChanged;
        base.Dispose();
    }

}
