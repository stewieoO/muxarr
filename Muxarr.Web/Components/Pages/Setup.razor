@page "/setup"
@using Microsoft.AspNetCore.Identity
@using Muxarr.Core.Config
@using Muxarr.Data.Entities
@using Muxarr.Web.Components.Layout
@using Muxarr.Web.Components.Pages.Settings
@layout SetupLayout
@attribute [StreamRendering]

<div class="card p-4">
    @* Step indicator *@
    <div class="d-flex justify-content-center gap-2 mb-4">
        <span class="badge @(_step == 1 ? "text-bg-primary" : "text-bg-secondary")">1. Security</span>
        <span class="badge @(_step == 2 ? "text-bg-primary" : "text-bg-secondary")">2. Integrations</span>
        <span class="badge @(_step == 3 ? "text-bg-primary" : "text-bg-secondary")">3. Profiles</span>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger py-2 small">@_error</div>
    }

    @if (_step == 1)
    {
        <h4 class="mb-2">Welcome to Muxarr</h4>
        <p class="text-muted small mb-4">
            Muxarr automates audio and subtitle track management for your media library.
            Let's get you set up. First, secure your instance with a username and password.
        </p>

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" class="form-control" @bind="_username"/>
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" @bind="_password"/>
        </div>
        <div class="mb-4">
            <label class="form-label">Confirm Password</label>
            <input type="password" class="form-control" @bind="_confirmPassword"/>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <button class="btn btn-link btn-sm text-muted text-decoration-none p-0" @onclick="SkipAuth">
                Skip <span class="small">(not recommended)</span>
            </button>
            <button class="btn btn-primary" @onclick="SaveAuth">
                Next <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </div>
    }
    else if (_step == 2)
    {
        <h4 class="mb-2">Connect Sonarr & Radarr</h4>
        <p class="text-muted small mb-4">
            Optionally connect your Sonarr and Radarr instances. Muxarr uses these to automatically
            process files when imported or renamed, and to retrieve original language metadata for
            smarter track filtering. You can always configure this later in Settings.
        </p>

        <EditForm Model="_sonarrService" FormName="arr-setup">
            <div class="border rounded p-4 mb-4">
                <h5 class="mb-3"><i class="bi bi-link-45deg me-2"></i>Muxarr URL</h5>
                <input type="text" class="form-control" @bind="_muxarrUrl" placeholder="http://muxarr:8183"/>
                <small class="form-text text-muted">
                    The URL that Sonarr/Radarr can reach Muxarr at. Example: <code>http://muxarr:8183</code> (Docker) or
                    <code>http://x.x.x.x:8183</code> (LAN IP)
                </small>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <ArrServiceCard Service="_sonarrService"
                                    GetWebhookUrl="@GetWebhookUrl"
                                    AutoSave="@PersistIntegrations"/>
                </div>
                <div class="col-md-6">
                    <ArrServiceCard Service="_radarrService"
                                    GetWebhookUrl="@GetWebhookUrl"
                                    AutoSave="@PersistIntegrations"/>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" @onclick="() => GoToStep(1)">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => GoToStep(3)">
                        Skip
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="SaveAndContinue">
                        Next <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>
        </EditForm>
    }
    else if (_step == 3)
    {
        <h4 class="mb-2">You're all set!</h4>
        <p class="text-muted small mb-3">
            Muxarr uses <strong>profiles</strong> to decide how to manage your media files.
            A profile defines:
        </p>
        <ul class="text-muted small mb-3">
            <li><strong>Directories</strong> — which folders to scan for media files</li>
            <li><strong>Audio settings</strong> — which audio languages to keep, whether to remove commentary or
                hearing-impaired tracks
            </li>
            <li><strong>Subtitle settings</strong> — same controls for subtitle tracks</li>
            <li><strong>Track name standardization</strong> — optionally rename tracks to a consistent format</li>
        </ul>
        <p class="text-muted small mb-4">
            You'll be taken to the profile editor to create your first profile. After saving, Muxarr will scan your
            library and start managing tracks automatically.
        </p>

        <div class="d-flex justify-content-between">
            <button class="btn btn-outline-secondary" @onclick="() => GoToStep(2)">
                <i class="bi bi-arrow-left me-1"></i> Back
            </button>
            <button class="btn btn-primary" @onclick="CompleteSetup">
                Create Profile <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </div>
    }
</div>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }
    [Inject] public required IToastService ToastService { get; set; }

    private static readonly PasswordHasher<string> Hasher = new();

    private int _step = 1;
    private string _username = "admin";
    private string _password = "";
    private string _confirmPassword = "";
    private string _muxarrUrl = "";
    private string _webhookApiKey = "";
    private string? _error;
    private Integration _sonarrService = new() { Name = "Sonarr", Type = IntegrationType.Sonarr };
    private Integration _radarrService = new() { Name = "Radarr", Type = IntegrationType.Radarr };

    private string GetWebhookUrl()
    {
        if (string.IsNullOrWhiteSpace(_muxarrUrl))
        {
            return "http://<muxarr-host>:8183/api/webhook";
        }

        var url = $"{_muxarrUrl.TrimEnd('/')}/api/webhook";
        if (!string.IsNullOrEmpty(_webhookApiKey))
        {
            url += $"?apikey={_webhookApiKey}";
        }

        return url;
    }

    protected override async Task OnInitializedAsync()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        if (await context.Configs.GetAsync<SetupConfig>() != null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        var existing = await context.Integrations.ToListAsync();
        var sonarr = existing.FirstOrDefault(c => c.Type == IntegrationType.Sonarr);
        var radarr = existing.FirstOrDefault(c => c.Type == IntegrationType.Radarr);
        if (sonarr != null)
        {
            _sonarrService = sonarr;
        }
        if (radarr != null)
        {
            _radarrService = radarr;
        }

        var webhookConfig = context.Configs.GetOrDefault<WebhookConfig>();
        _muxarrUrl = !string.IsNullOrWhiteSpace(webhookConfig.MuxarrUrl)
            ? webhookConfig.MuxarrUrl
            : NavigationManager.BaseUri.TrimEnd('/');
        _webhookApiKey = webhookConfig.ApiKey ?? "";
    }

    private void GoToStep(int step)
    {
        _error = null;
        _step = step;
    }

    private async Task SaveAuth()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_username))
        {
            _error = "Username is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_password))
        {
            _error = "Password is required.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        await using var context = await ContextFactory.CreateDbContextAsync();
        context.Configs.Set(new AuthConfig
        {
            Username = _username.Trim(),
            PasswordHash = Hasher.HashPassword(_username.Trim(), _password)
        }, AuthConfig.Key);
        await context.SaveChangesAsync();

        GoToStep(2);
    }

    private void SkipAuth()
    {
        GoToStep(2);
    }

    private async Task SaveAndContinue()
    {
        await PersistIntegrations();
        GoToStep(3);
    }

    private async Task PersistIntegrations()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();

        foreach (var svc in new[] { _sonarrService, _radarrService })
        {
            svc.Url = svc.Url.SanitizeUrl();

            if (svc.Id == 0)
            {
                context.Integrations.Add(svc);
            }
            else
            {
                var existing = await context.Integrations.FindAsync(svc.Id);
                if (existing != null)
                {
                    existing.Url = svc.Url;
                    existing.ApiKey = svc.ApiKey;
                }
            }
        }

        var webhookConfig = context.Configs.GetOrDefault<WebhookConfig>();
        webhookConfig.MuxarrUrl = _muxarrUrl.SanitizeUrl();

        if (string.IsNullOrEmpty(webhookConfig.ApiKey))
        {
            webhookConfig.ApiKey = Guid.NewGuid().ToString("N");
        }

        _webhookApiKey = webhookConfig.ApiKey;
        context.Configs.Set(webhookConfig);

        await context.SaveChangesAsync();
    }

    private async Task CompleteSetup()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        context.Configs.Set(new SetupConfig { CompletedAt = DateTime.UtcNow });
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/settings/profile/0");
    }

}
